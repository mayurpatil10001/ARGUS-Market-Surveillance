# ── ARGUS backend environment (local dev) ──────────────────────────────────────
# SQLite — no Postgres/Redis required for local dev
DATABASE_URL=sqlite:///./argus_local.db

# Keep Postgres URL in case you switch later
POSTGRES_URL=postgresql://argus:argus@localhost:5432/argus

# Redis — optional, backend gracefully marks "not_configured"
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=argus_dev_secret_do_not_use_in_production
ADMIN_PASSWORD=argus2024

# External integrations (not required for local dev)
KAFKA_BOOTSTRAP=localhost:9092
NSE_ARCHIVE_BASE=https://archives.nseindia.com
BSE_ARCHIVE_BASE=https://www.bseindia.com
ZERODHA_API_KEY=your_key_here
ZERODHA_ACCESS_TOKEN=your_token_here

# Thresholds
ALERT_SCORE_THRESHOLD=7.5
DNA_SIMILARITY_THRESHOLD=0.85

APP_ENV=development
