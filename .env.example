# SENTINEL — Digital Threat Detection Platform
# PS-402: Detection of Digital Threats & Malicious Content

# ── Core services ─────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql://sentinel:sentinel@postgres:5432/sentinel
REDIS_URL=redis://redis:6379
KAFKA_BOOTSTRAP=kafka:9092

# ── Platform sources (PS-402) ─────────────────────────────────────────────────
PLATFORM_SOURCES=twitter,reddit,telegram,web
CONTENT_SCAN_INTERVAL=30

# ── Threat scoring thresholds ─────────────────────────────────────────────────
THREAT_SCORE_THRESHOLD=7.5
ALERT_SCORE_THRESHOLD=7.5
DNA_SIMILARITY_THRESHOLD=0.85

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
