# ARGUS Production Environment Variables — Template
# Copy to .env.prod and fill in ALL CHANGE_ME values before running bootstrap.
# This file IS committed to git. The actual .env.prod is NOT.

# === Database ===
POSTGRES_URL=postgresql://argus:CHANGE_ME@postgres:5432/argus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === Redis ===
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === Kafka ===
KAFKA_BOOTSTRAP=kafka:9092

# === Market Data ===
NSE_ARCHIVE_BASE=https://archives.nseindia.com
BSE_ARCHIVE_BASE=https://www.bseindia.com

# === Broker API (Zerodha) ===
ZERODHA_API_KEY=CHANGE_ME
ZERODHA_ACCESS_TOKEN=CHANGE_ME

# === ARGUS Thresholds ===
ALERT_SCORE_THRESHOLD=7.5
DNA_SIMILARITY_THRESHOLD=0.85
PS402_MARKET_MOVING_THRESHOLD=0.6

# === Auth ===
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === Reports ===
REPORTS_DIR=/tmp/argus_reports

# === Social API (optional — leave blank for heuristic mode) ===
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# === Notifications (optional) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
